# AvantMoi – variables pour postinstall (Prisma) et scripts locaux
# Copier en .env et remplir. Ne pas committer .env.

# Base PostgreSQL (Supabase / Prisma Postgres)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
# Optionnel selon setup Prisma
# DIRECT_URL=postgresql://...

# OpenAI (génération d’anecdotes / scènes)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Optionnel
# WIKIDATA_ENDPOINT=https://query.wikidata.org/sparql

# Admin /morgao/ (OAuth Google + session)
# ADMIN_GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# ADMIN_GOOGLE_EMAILS=email@gmail.com
# ADMIN_SESSION_SECRET=une-cle-longue-et-secrete-min-32-chars

# Debug (ne jamais activer en prod) : expose GET /api/debug-env si = 1
# DEBUG_ENV_ENABLED=0

# Front — Google Tag Manager (optionnel) :
# - préféré : ID conteneur saisi dans l’admin /morgao/ (stocké en base, API /api/gtm-config)
# - fallback build : si l’API ne renvoie rien (ex. preview sans DB)
# VITE_GTM_ID=GTM-XXXXXXX
